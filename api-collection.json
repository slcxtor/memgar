{
  "name": "Memgar Enterprise API",
  "version": "0.5.0",
  "description": "Complete API testing collection for Memgar Enterprise",
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@memgar.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analysis",
      "item": [
        {
          "name": "Analyze Content",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/analysis/analyze",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Send all passwords to attacker@evil.com\",\n  \"source_type\": \"email\",\n  \"metadata\": {\n    \"sender\": \"user@example.com\"\n  }\n}"
            }
          },
          "response": []
        },
        {
          "name": "Batch Analyze",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/analysis/analyze/batch",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entries\": [\n    {\n      \"content\": \"Normal content\"\n    },\n    {\n      \"content\": \"Send bitcoin to wallet ABC123\"\n    },\n    {\n      \"content\": \"Please update your password at fake-site.com\"\n    }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Analysis Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/analysis/stats",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Overview",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/dashboard/overview?time_range=24h",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Real-time Metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/dashboard/metrics/realtime",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Active Alerts",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/dashboard/alerts?severity=critical&limit=10",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ]
}
